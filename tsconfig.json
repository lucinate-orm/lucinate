{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolvePackageJsonExports": false,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "build",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "paths": {
      "knex": ["./node_modules/knex/types/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "index.ts", "examples/**/*.ts"],
  "exclude": ["node_modules", "build", "src/bindings", "src/test_utils"]
}
